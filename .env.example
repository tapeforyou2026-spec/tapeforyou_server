# =============================================
# TAPESFORYOU BACKEND - ENVIRONMENT VARIABLES
# =============================================

# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=tape_for_you_with_node
DATABASE_USER=postgres
DATABASE_PASSWORD=root

# JWT
JWT_SECRET=your_super_secret_jwt_key_min_64_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_64_chars
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Cookie
COOKIE_SECRET=your_cookie_secret_key

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_SECRET=your_razorpay_secret

# Shiprocket
SHIPROCKET_EMAIL=your@email.com
SHIPROCKET_PASSWORD=your_shiprocket_password

# SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_NAME=Tapes For You
SMTP_FROM_EMAIL=noreply@tapesforyou.in

# URLs
BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173

# GST
GST_PERCENT=18

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=src/uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
